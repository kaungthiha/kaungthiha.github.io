</Base>

<style>
  .resume-container {
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
    padding: clamp(5rem, 4rem + 6vw, 7rem) clamp(1rem, 0.5rem + 1.5vw, 1.5rem) 4rem;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-body, #4a5260);
  }
  .resume-content { max-width: 100%; }

  /* Spacing utilities (replaces the few Bootstrap classes the page used) */
  .mt-2 { margin-top: 0.5rem; }
  .mt-3 { margin-top: 1rem; }
  .mb-0 { margin-bottom: 0; }

  .fixed-easy-nav {
    position: fixed;
    top: 100px;
    left: 20px;
    width: 240px;
    padding: 1.5rem;
    border: 1px solid var(--outline-variant, #c1c6d7);
    border-radius: var(--r-lg, 1rem);
    background: var(--frost-surface, #fff);
    font-size: 0.85em;
    z-index: 1000;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }
  .fixed-easy-nav h3 {
    color: var(--text-strong, #171d27);
    font-family: var(--font-sans, 'Plus Jakarta Sans', sans-serif);
    font-size: 1em;
    margin: 0 0 1rem;
    border-bottom: 2px solid var(--primary, #0059bb);
    padding-bottom: 0.5rem;
  }
  .fixed-easy-nav ul { list-style: none; padding: 0; margin: 0; }
  .fixed-easy-nav li { margin-bottom: 0.4rem; }
  .fixed-easy-nav a {
    color: var(--text-muted, #737a7f);
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
    padding: 0.2rem 0;
    font-size: 0.9em;
  }
  .fixed-easy-nav a:hover { color: var(--primary, #0059bb); }

  .content-area { margin-left: 280px; }

  @media (max-width: 1200px) {
    .fixed-easy-nav { position: static; width: 100%; margin-bottom: 2rem; }
    .content-area { margin-left: 0; width: 100%; }
  }

  .contact-info {
    background: var(--surface-container-low, #eef4fa);
    padding: 2rem;
    border-radius: var(--r-xl, 1.5rem);
    margin-bottom: 3rem;
    text-align: center;
  }
  .contact-info p { margin: 0.5rem 0; font-size: 1.05em; }
  .contact-info strong { color: var(--primary, #0059bb); }

  .section-header {
    background: var(--accent-gradient, linear-gradient(135deg, #2480fd, #22d1ff));
    color: #fff;
    padding: 1.25rem 2rem;
    margin: 3rem 0 2rem;
    border-radius: var(--r-lg, 1rem);
    font-size: 1.3em;
    font-weight: 600;
    font-family: var(--font-sans, 'Plus Jakarta Sans', sans-serif);
  }
  .section-header h2 { margin: 0; display: flex; align-items: center; font-size: 1em; }
  .section-icon { margin-right: 1rem; font-size: 1.2em; }

  .entry {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding: 1.75rem 2rem;
    background: var(--frost-surface, #fff);
    border-radius: var(--r-lg, 1rem);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    border-left: 4px solid var(--primary, #0059bb);
  }
  .entry-details { flex: 1; margin-right: 2rem; }
  .entry-title {
    font-family: var(--font-sans, 'Plus Jakarta Sans', sans-serif);
    font-weight: 700;
    font-size: 1.15em;
    color: var(--text-strong, #171d27);
    margin-bottom: 0.4rem;
  }
  .entry-subtitle { font-size: 1em; color: var(--text-muted, #737a7f); margin-bottom: 0.75rem; }
  .entry-details ul { margin: 0; padding-left: 1.1rem; }
  .entry-details li { margin-bottom: 0.35rem; }
  .entry-dates {
    font-size: 0.85em;
    color: var(--text-body, #4a5260);
    background: var(--surface-container, #e8eff4);
    padding: 0.6rem 1.25rem;
    border-radius: var(--r-pill, 9999px);
    white-space: nowrap;
    font-weight: 500;
    min-width: 160px;
    text-align: center;
  }
  @media (max-width: 640px) {
    .entry { flex-direction: column; }
    .entry-details { margin-right: 0; margin-bottom: 1rem; }
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin: 2rem 0;
  }
  .skill-item {
    background: var(--surface-container-low, #eef4fa);
    padding: 1.5rem;
    border-radius: var(--r-lg, 1rem);
    border-left: 4px solid var(--primary, #0059bb);
  }
  .skill-item strong {
    color: var(--text-strong, #171d27);
    display: block;
    margin-bottom: 0.6rem;
    font-size: 1.05em;
  }
</style>
