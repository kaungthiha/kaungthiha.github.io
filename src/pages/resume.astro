      <div class="resume-content">
        <div class="contact-info">
          <p>
            📧 <strong>kaungthiha.3@gmail.com</strong> | 🔗 <strong>www.linkedin.com/in/kaungthiha</strong> | 📞 <strong>757-969-9628</strong> | 📍 San Francisco, CA
          </p>
