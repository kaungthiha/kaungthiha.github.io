    <div class="fixed-easy-nav">
      <h3>📋 Quick Navigation</h3>
      <ul>
        <li><a href="#education">🏫 Education</a></li>
        <li><a href="#skills-certifications">🥷 Skills & Certifications</a></li>
        <li><a href="#work-experience">🖥️ Work Experience</a></li>
        <li><a href="#leadership-experience">🪅 Leadership Experience</a></li>
