            </ul>
          </div>
          <div class="entry-dates">May 2022 - Dec 2023</div>
        </div>

        <div class="section-header">
          <h2 id="leadership-experience"><span class="section-icon">🪅</span> Leadership Experience</h2>
        </div>

        <div class="entry">
          <div class="entry-details">
            <div class="entry-title">Alpha Phi Omega Service Fraternity</div>
            <div class="entry-subtitle">Finance Chair, Pledge Trainer</div>
